<!DOCTYPE html>
<html lang="gu">
<head>
    <meta charset="UTF-8">
    <title>Desi Videos Demo</title>
</head>
<body>

    <!-- વિડીયો ૧ -->
    <div class="thumb-list__item">
        <!-- class="video-thumb__image-container" હોવો જરૂરી છે અને href માં વિડીયો લિંક -->
        <a class="video-thumb__image-container" href="https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4">
            <!-- class="thumb-image-container__image" હોવો જરૂરી છે અને src માં ઈમેજ લિંક -->
            <img class="thumb-image-container__image" src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=500" alt="thumb" />
        </a>
        <!-- class="video-thumb-info__name" હોવો જરૂરી છે અને title માં નામ -->
        <a class="video-thumb-info__name" title="અહીં તમારા પહેલા વિડીયોનું નામ લખો" href="#"></a>
    </div>

    <!-- વિડીયો ૨ -->
    <div class="thumb-list__item">
        <a class="video-thumb__image-container" href="https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ElephantsDream.mp4">
            <img class="thumb-image-container__image" src="https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=500" alt="thumb" />
        </a>
        <a class="video-thumb-info__name" title="અહીં તમારા બીજા વિડીયોનું નામ લખો" href="#"></a>
    </div>

</body>
</html>
